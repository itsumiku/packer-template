#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  source:
    id: ubuntu-server-minimal
  kernel:
    package: linux-virtual
  identity:
    hostname: ubuntu
    username: ubuntu
    password: "$6$rounds=4096$packer$boWUDPn2ItbIVp75vZkcB9enktYcH/yND03ZqeO.xN1ydPY2A8ZRsbTDbbiRlToGQ97O4.AM3Tdw9FQoPk41k."
  ssh:
    install-server: true
    allow-pw: true
  updates: all
  network:
    version: 2
    ethernets:
      all-en:
        match:
          name: "e*"
        dhcp4: true
        dhcp6: false
        optional: true
  storage:
    config:
      - type: disk
        id: disk-sda
        ptable: gpt
        match:
          size: largest
      - type: partition
        id: esp
        device: disk-sda
        size: 538M
        flag: esp
        grub_device: true
      - type: partition
        id: root-part
        device: disk-sda
        size: -1
      - type: format
        id: fs-esp
        volume: esp
        fstype: fat32
      - type: format
        id: fs-root
        volume: root-part
        fstype: ext4
      - type: mount
        id: mount-esp
        device: fs-esp
        path: /boot/efi
      - type: mount
        id: mount-root
        device: fs-root
        path: /
  packages:
    - python3
  late-commands:
    - curtin in-target -- sh -c 'echo bmV0d29yazoKICB2ZXJzaW9uOiAyCiAgZXRoZXJuZXRzOgogICAgYWxsLWVuOgogICAgICBtYXRjaDoKICAgICAgICBuYW1lOiAiZSoiCiAgICAgIGRoY3A0OiB0cnVlCiAgICAgIGRoY3A2OiBmYWxzZQogICAgICBvcHRpb25hbDogdHJ1ZQo= | base64 -d > /etc/netplan/00-installer-config.yaml'
    - curtin in-target -- sh -c 'echo "root:packer" | chpasswd'
    - curtin in-target -- passwd -u root
    - curtin in-target -- sh -c 'printf "PermitRootLogin yes\nPasswordAuthentication yes\n" > /etc/ssh/sshd_config.d/01-packer.conf'
    - curtin in-target -- systemctl unmask ssh.service
    - curtin in-target -- systemctl enable ssh.service
